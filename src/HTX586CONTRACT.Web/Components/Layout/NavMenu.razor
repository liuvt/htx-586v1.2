@inject DriverRegistrationNotificationState RegistrationNotificationState
@inject DriverNotificationState DriverNotificationState
@inject AuthenticationStateProvider AuthenticationStateProvider
@implements IDisposable

<MudNavMenu Class="enterprise-nav">
    <AuthorizeView Roles="Driver" Context="driverAuth">
        <Authorized>
            <div class="nav-section-label">Không gian tài xế</div>
            <MudNavLink Href="/driver/dashboard" Icon="@Icons.Material.Filled.SpaceDashboard" Match="NavLinkMatch.All">
                Tổng quan
            </MudNavLink>
            <MudNavLink Href="/driver/contracts" Icon="@Icons.Material.Filled.Article">
                Hợp đồng của tôi
            </MudNavLink>
            <MudNavLink Href="/driver/contracts/create" Icon="@Icons.Material.Filled.PostAdd">
                Tạo hợp đồng mới
            </MudNavLink>
            <MudNavLink Href="/driver/notifications" Icon="@Icons.Material.Filled.NotificationsActive">
                <span class="nav-link-content">
                    <span>Thông báo</span>
                    @if (DriverNotificationState.UnreadCount > 0)
                    {
                        <span class="nav-count">@DriverNotificationState.UnreadCount</span>
                    }
                </span>
            </MudNavLink>
            <MudNavLink Href="/driver/account" Icon="@Icons.Material.Filled.AccountCircle">
                Hồ sơ cá nhân
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="Owner" Context="ownerAuth">
        <Authorized>
            <div class="nav-section-label">Điều hành hệ thống</div>
            <MudNavLink Href="/owner/dashboard" Icon="@Icons.Material.Filled.SpaceDashboard" Match="NavLinkMatch.All">
                Tổng quan điều hành
            </MudNavLink>

            <MudNavGroup Title="Tổ chức & nhân sự" Icon="@Icons.Material.Filled.CorporateFare" Expanded="true">
                <MudNavLink Href="/owner/companies" Icon="@Icons.Material.Filled.Apartment">
                    Công ty / Văn phòng
                </MudNavLink>
                <MudNavLink Href="/admin/accounts" Icon="@Icons.Material.Filled.AdminPanelSettings">
                    Tài khoản Admin
                </MudNavLink>
                <MudNavLink Href="/admin/driver-accounts" Icon="@Icons.Material.Filled.Badge">
                    Tài xế
                </MudNavLink>
                <MudNavLink Href="/admin/driver-registrations" Icon="@Icons.Material.Filled.PersonAddAlt1">
                    <span class="nav-link-content">
                        <span>Yêu cầu đăng ký</span>
                        @if (RegistrationNotificationState.UnseenCount > 0)
                        {
                            <span class="nav-count nav-count-warning">@RegistrationNotificationState.UnseenCount</span>
                        }
                    </span>
                </MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="Vận hành kinh doanh" Icon="@Icons.Material.Filled.Hub" Expanded="true">
                <MudNavLink Href="/admin/vehicles" Icon="@Icons.Material.Filled.DirectionsCarFilled">
                    Xe &amp; chủ sở hữu
                </MudNavLink>
                <MudNavLink Href="/admin/customers" Icon="@Icons.Material.Filled.Groups">
                    Khách hàng
                </MudNavLink>
                <MudNavLink Href="/owner/contracts" Icon="@Icons.Material.Filled.Description">
                    Hợp đồng
                </MudNavLink>
                <MudNavLink Href="/owner/reports" Icon="@Icons.Material.Filled.QueryStats">
                    Báo cáo &amp; xuất Excel
                </MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="Cấu hình nâng cao" Icon="@Icons.Material.Filled.Tune" Expanded="false">
                <MudNavLink Href="/admin/pdf-layout-designer" Icon="@Icons.Material.Filled.DesignServices">
                    Thiết kế mẫu PDF
                </MudNavLink>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="Admin" Context="adminAuth">
        <Authorized>
            <div class="nav-section-label">Quản trị đơn vị</div>
            <MudNavLink Href="/admin/dashboard" Icon="@Icons.Material.Filled.SpaceDashboard" Match="NavLinkMatch.All">
                Tổng quan
            </MudNavLink>

            <MudNavGroup Title="Nguồn lực vận hành" Icon="@Icons.Material.Filled.Hub" Expanded="true">
                <MudNavLink Href="/admin/vehicles" Icon="@Icons.Material.Filled.DirectionsCarFilled">
                    Xe &amp; chủ sở hữu
                </MudNavLink>
                <MudNavLink Href="/admin/driver-accounts" Icon="@Icons.Material.Filled.Badge">
                    Tài xế
                </MudNavLink>
                <MudNavLink Href="/admin/driver-registrations" Icon="@Icons.Material.Filled.PersonAddAlt1">
                    <span class="nav-link-content">
                        <span>Yêu cầu đăng ký</span>
                        @if (RegistrationNotificationState.UnseenCount > 0)
                        {
                            <span class="nav-count nav-count-warning">@RegistrationNotificationState.UnseenCount</span>
                        }
                    </span>
                </MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="Hợp đồng & khách hàng" Icon="@Icons.Material.Filled.BusinessCenter" Expanded="true">
                <MudNavLink Href="/admin/customers" Icon="@Icons.Material.Filled.Groups">
                    Khách hàng
                </MudNavLink>
                <MudNavLink Href="/admin/contracts" Icon="@Icons.Material.Filled.Description">
                    Hợp đồng
                </MudNavLink>
                <MudNavLink Href="/admin/reports" Icon="@Icons.Material.Filled.QueryStats">
                    Báo cáo &amp; xuất Excel
                </MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="Cấu hình" Icon="@Icons.Material.Filled.SettingsSuggest" Expanded="false">
                <MudNavLink Href="/admin/pdf-layout-designer" Icon="@Icons.Material.Filled.DesignServices">
                    Thiết kế mẫu PDF
                </MudNavLink>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>

@code {
    protected override async Task OnInitializedAsync()
    {
        try
        {
            RegistrationNotificationState.Changed += OnNotificationChanged;
            DriverNotificationState.Changed += OnNotificationChanged;

            var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            if (auth.User.IsInRole("Owner") || auth.User.IsInRole("Admin"))
                await RegistrationNotificationState.RefreshAsync();

            if (auth.User.IsInRole("Driver"))
            {
                var driverId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
                await DriverNotificationState.RefreshAsync(driverId);
            }
        }
        catch
        {
            // Navigation vẫn hoạt động khi dữ liệu thông báo tạm thời chưa sẵn sàng.
        }
    }

    private void OnNotificationChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        RegistrationNotificationState.Changed -= OnNotificationChanged;
        DriverNotificationState.Changed -= OnNotificationChanged;
    }
}
