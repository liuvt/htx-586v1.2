@page "/error"
@page "/error/{StatusCode:int}"
@page "/account/access-denied"
@attribute [AllowAnonymous]

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>@PageTitleText</PageTitle>

<section class="system-error-page" aria-labelledby="system-error-title">
    <div class="system-error-glow system-error-glow-one"></div>
    <div class="system-error-glow system-error-glow-two"></div>

    <MudPaper Class="system-error-card" Elevation="0">
        <div class="system-error-visual" aria-hidden="true">
            <div class="system-error-orbit orbit-one"></div>
            <div class="system-error-orbit orbit-two"></div>
            <div class="system-error-icon-wrap">
                <MudIcon Icon="@ErrorIcon" Class="system-error-icon" />
            </div>
            <div class="system-error-code">@DisplayCode</div>
        </div>

        <div class="system-error-content">
            <MudChip T="string"
                     Size="Size.Small"
                     Variant="Variant.Outlined"
                     Color="@AccentColor"
                     Class="system-error-chip">
                @Eyebrow
            </MudChip>

            <h1 id="system-error-title" class="system-error-title">
                @Title
            </h1>

            <MudText Typo="Typo.body1" Class="system-error-description">
                @Description
            </MudText>

            @if (!string.IsNullOrWhiteSpace(SafeReturnUrl))
            {
                <div class="system-error-request">
                    <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" />
                    <div>
                        <span>Đường dẫn được yêu cầu</span>
                        <strong title="@SafeReturnUrl">@SafeReturnUrl</strong>
                    </div>
                </div>
            }

            <div class="system-error-actions">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           StartIcon="@PrimaryActionIcon"
                           OnClick="GoToPrimaryPage">
                    @PrimaryActionText
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="GoHome">
                    Trang chủ
                </MudButton>

                @if (_isAuthenticated)
                {
                    <MudButton Variant="Variant.Text"
                               Color="Color.Secondary"
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.Logout"
                               Href="/account/logout?returnUrl=/account/login">
                        Đổi tài khoản
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Text"
                               Color="Color.Secondary"
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.Login"
                               Href="@LoginUrl">
                        Đăng nhập
                    </MudButton>
                }
            </div>

            <div class="system-error-help">
                <MudIcon Icon="@Icons.Material.Filled.SupportAgent" Size="Size.Small" />
                <span>
                    Nếu bạn cần truy cập chức năng này, hãy liên hệ Owner hoặc Admin để kiểm tra lại quyền tài khoản.
                </span>
            </div>
        </div>
    </MudPaper>
</section>

@code {
    [Parameter]
    public int? StatusCode { get; set; }

    [SupplyParameterFromQuery(Name = "ReturnUrl")]
    public string? ReturnUrl { get; set; }

    private bool _isAuthenticated;
    private string _roleHomeUrl = "/";
    private string _roleName = "người dùng";

    private int EffectiveStatusCode
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);

            if (relativePath.StartsWith(
                    "account/access-denied",
                    StringComparison.OrdinalIgnoreCase))
            {
                return 403;
            }

            return StatusCode is int statusCode &&
                   statusCode is >= 400 and <= 599
                ? statusCode
                : 500;
        }
    }

    private string? SafeReturnUrl
    {
        get
        {
            if (IsLocalUrl(ReturnUrl))
                return ReturnUrl;

            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);

            if (string.IsNullOrWhiteSpace(relativePath) ||
                relativePath.StartsWith("error", StringComparison.OrdinalIgnoreCase) ||
                relativePath.StartsWith(
                    "account/access-denied",
                    StringComparison.OrdinalIgnoreCase))
            {
                return null;
            }

            var currentUrl = "/" + relativePath;

            return IsLocalUrl(currentUrl)
                ? currentUrl
                : null;
        }
    }

    private bool CanRetryCurrentPage =>
        EffectiveStatusCode is 408 or 500 or 503 &&
        !string.IsNullOrWhiteSpace(SafeReturnUrl);

    private string DisplayCode => EffectiveStatusCode.ToString();

    private string PageTitleText => $"{DisplayCode} - {Title}";

    private string Eyebrow => EffectiveStatusCode switch
    {
        401 => "CHƯA ĐĂNG NHẬP",
        403 => "KHÔNG ĐỦ QUYỀN TRUY CẬP",
        404 => "KHÔNG TÌM THẤY NỘI DUNG",
        408 => "YÊU CẦU QUÁ THỜI GIAN",
        500 => "HỆ THỐNG GẶP SỰ CỐ",
        503 => "DỊCH VỤ TẠM GIÁN ĐOẠN",
        _ => "KHÔNG THỂ MỞ NỘI DUNG"
    };

    private string Title => EffectiveStatusCode switch
    {
        401 => "Bạn cần đăng nhập để tiếp tục",
        403 => "Bạn không có quyền mở trang này",
        404 => "Trang bạn tìm kiếm không tồn tại",
        408 => "Kết nối đã mất quá nhiều thời gian",
        500 => "Có lỗi xảy ra khi xử lý nội dung",
        503 => "Hệ thống đang tạm thời gián đoạn",
        _ => "Không thể hiển thị nội dung được yêu cầu"
    };

    private string Description => EffectiveStatusCode switch
    {
        401 => "Phiên đăng nhập có thể đã hết hạn hoặc nội dung này chỉ dành cho người dùng đã xác thực.",
        403 => $"Tài khoản hiện tại thuộc vai trò {_roleName} và chưa được cấp quyền sử dụng chức năng này. Giao diện hệ thống vẫn được giữ nguyên để bạn có thể tiếp tục điều hướng.",
        404 => "Đường dẫn có thể đã thay đổi, bị nhập sai hoặc nội dung đã được chuyển sang khu vực khác trong hệ thống.",
        408 => "Kết nối đến máy chủ chưa hoàn thành. Bạn có thể tải lại trang hoặc quay về khu vực làm việc chính.",
        500 => "Ứng dụng không thể hoàn tất yêu cầu vừa rồi. Hãy thử tải lại; nếu lỗi lặp lại, vui lòng gửi thông tin cho quản trị viên.",
        503 => "Một dịch vụ cần thiết đang bảo trì hoặc chưa sẵn sàng. Vui lòng thử lại sau ít phút.",
        _ => "Yêu cầu hiện tại chưa thể được xử lý. Bạn vẫn có thể quay về khu vực làm việc phù hợp với tài khoản."
    };

    private string ErrorIcon => EffectiveStatusCode switch
    {
        401 => Icons.Material.Filled.Lock,
        403 => Icons.Material.Filled.AdminPanelSettings,
        404 => Icons.Material.Filled.SearchOff,
        408 => Icons.Material.Filled.TimerOff,
        500 => Icons.Material.Filled.ErrorOutline,
        503 => Icons.Material.Filled.CloudOff,
        _ => Icons.Material.Filled.WarningAmber
    };

    private Color AccentColor => EffectiveStatusCode switch
    {
        403 => Color.Warning,
        404 => Color.Info,
        500 => Color.Error,
        503 => Color.Warning,
        _ => Color.Primary
    };

    private string PrimaryActionText => EffectiveStatusCode == 401
        ? "Đăng nhập"
        : CanRetryCurrentPage
            ? "Tải lại trang"
            : "Về khu vực của tôi";

    private string PrimaryActionIcon => EffectiveStatusCode == 401
        ? Icons.Material.Filled.Login
        : CanRetryCurrentPage
            ? Icons.Material.Filled.Refresh
            : Icons.Material.Filled.SpaceDashboard;

    private string LoginUrl
    {
        get
        {
            if (string.IsNullOrWhiteSpace(SafeReturnUrl))
                return "/account/login";

            return "/account/login?returnUrl=" +
                   Uri.EscapeDataString(SafeReturnUrl);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            var state =
                await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = state.User;

            _isAuthenticated = user.Identity?.IsAuthenticated == true;

            if (user.IsInRole("Owner"))
            {
                _roleName = "Owner";
                _roleHomeUrl = "/owner/dashboard";
            }
            else if (user.IsInRole("Admin"))
            {
                _roleName = "Admin";
                _roleHomeUrl = "/admin/dashboard";
            }
            else if (user.IsInRole("Driver"))
            {
                _roleName = "Tài xế";
                _roleHomeUrl = "/driver/dashboard";
            }
            else
            {
                _roleName = _isAuthenticated
                    ? "chưa được phân quyền"
                    : "khách";
                _roleHomeUrl = _isAuthenticated
                    ? "/"
                    : "/account/login";
            }
        }
        catch
        {
            _isAuthenticated = false;
            _roleName = "khách";
            _roleHomeUrl = "/account/login";
        }
    }

    private void GoToPrimaryPage()
    {
        if (EffectiveStatusCode == 401)
        {
            Navigation.NavigateTo(LoginUrl, forceLoad: true);
            return;
        }

        if (CanRetryCurrentPage)
        {
            Navigation.NavigateTo(
                SafeReturnUrl!,
                forceLoad: true,
                replace: true);
            return;
        }

        Navigation.NavigateTo(_roleHomeUrl, replace: true);
    }

    private void GoHome()
    {
        Navigation.NavigateTo(
            _isAuthenticated ? _roleHomeUrl : "/account/login",
            replace: true);
    }

    private static bool IsLocalUrl(string? url)
    {
        return !string.IsNullOrWhiteSpace(url) &&
               url.StartsWith("/", StringComparison.Ordinal) &&
               !url.StartsWith("//", StringComparison.Ordinal) &&
               !url.StartsWith("/\\", StringComparison.Ordinal);
    }
}
