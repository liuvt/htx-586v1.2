@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

@code {
    private bool _redirected;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _redirected)
            return;

        _redirected = true;

        var authenticationState =
            await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var principal = authenticationState.User;
        var returnUrl = GetCurrentLocalUrl();

        if (principal.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo(
                "/account/login?returnUrl=" + Uri.EscapeDataString(returnUrl),
                forceLoad: true,
                replace: true);

            return;
        }

        Navigation.NavigateTo(
            "/account/access-denied?ReturnUrl=" + Uri.EscapeDataString(returnUrl),
            replace: true);
    }

    private string GetCurrentLocalUrl()
    {
        var relativeUrl = Navigation.ToBaseRelativePath(Navigation.Uri);

        if (string.IsNullOrWhiteSpace(relativeUrl))
            return "/";

        return "/" + relativeUrl;
    }
}
